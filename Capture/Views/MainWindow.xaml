<!-- preserve: 트레이 전용 — 창 숨김, ShowInTaskbar=false -->
<!-- ADR-102: H.NotifyIcon.Wpf TaskbarIcon -->
<Window x:Class="Capture.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Visibility="Hidden"
        ShowInTaskbar="False"
        Width="0" Height="0"
        WindowStyle="None"
        AllowsTransparency="True">

    <Grid>
        <!-- ADR-102: TaskbarIcon
             ContextMenu 는 별도 visual tree 라 DataContext 자동 상속 안 됨.
             TaskbarIcon.DataContext 는 코드비하인드(Views/MainWindow.xaml.cs) 에서 MainViewModel 로 명시 할당,
             ContextMenu 는 PlacementTarget(=TrayIcon) 의 DataContext 를 끌어쓴다. -->
        <tb:TaskbarIcon x:Name="TrayIcon"
                        ToolTipText="Capture It !"
                        IconSource="/Resources/tray-aperture.ico"
                        DoubleClickCommand="{Binding CaptureCommand}">

            <tb:TaskbarIcon.ContextMenu>
                <!-- DataContext 는 코드비하인드(MainWindow.xaml.cs)에서 명시 할당 —
                     H.NotifyIcon.Wpf 의 ContextMenu 는 별도 visual tree 라
                     RelativeSource Self.PlacementTarget 바인딩이 깨지는 케이스가 있음. -->
                <ContextMenu x:Name="TrayMenu">
                    <MenuItem Header="Capture" Command="{Binding CaptureCommand}"/>
                    <Separator/>
                    <MenuItem Header="Load from image file" Command="{Binding LoadFromFileCommand}"/>
                    <Separator/>
                    <MenuItem Header="Exit" Command="{Binding ExitAppCommand}"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Grid>
</Window>
