<!-- phase: engineering -->
<!-- preserve: TopMost, ContextMenu вҖ” migration-mapping.md В§13-1 -->
<!-- 7м°Ё fix: AllowsTransparency=True ліөкө¬ + Opacity л°”мқёл”© ліөкө¬ (WPF н‘ңмӨҖ м•ҢнҢҢ мӮ¬мҡ©).
     6м°Ё Layered Window API л°©мӢқмқҖ WPF л ҢлҚ”л§Ғ нҢҢмқҙн”„лқјмқёкіј м¶©лҸҢ вҖ” Opacity м Ғмҡ© м•Ҳ лҗЁ.
     л©ҖнӢ° мңҲлҸ„мҡ° к°ҖмӢңм„ұмқҖ ShowActivated=False (мҪ”л“ңл№„н•ҳмқёл“ң) лЎң мғҲ мңҲлҸ„мҡ°к°Җ кё°мЎҙ мңҲлҸ„мҡ°лҘј
     л№„нҷңм„ұнҷ”н•ҳм§Җ м•ҠлҸ„лЎқ нҡҢн”ј. -->
<!-- ліҙк°• 2м°Ё: Window л“ңлһҳк·ё вҶ’ WindowDragBehavior мІЁл¶Җ мҶҚм„ұ, MouseWheelВ·Drop вҶ’ Behavior ICommand -->
<!-- 8м°Ё: EffectiveOpacity л°”мқёл”© көҗмІҙ (м»ҙнҢ©нҠё мӢң 1.0), м»ҙнҢ©нҠё лӘЁлҚҳ л””мһҗмқё,
          Send EmailВ·Overlay л©”лүҙ м ңкұ°, MouseMove/MouseUp мқҙлІӨнҠё м ңкұ°, KeyDown м¶”к°Җ (ADR-006) -->
<!-- 9м°Ё: м»ҙнҢ©нҠё мқёл””мјҖмқҙн„° мҚёл„Өмқј кё°л°ҳ лӘЁлҚҳ л””мһҗмқё (48Г—48, CornerRadius=12, мҚёл„Өмқј нҒҙлҰҪ, л№Ёк°„ м җ) -->
<!-- 10м°Ё: Ctrl+л“ңлһҳк·ё л“ңлЎңмһү + мғүмғҒ нҢ”л ҲнҠё (InkCanvas мҳӨлІ„л Ҳмқҙ + мҡ°мғҒлӢЁ нҢ”л ҲнҠё нҢЁл„җ) -->
<!-- 11м°Ё: л¶Җмң  нҢ”л ҲнҠё м ңкұ° вҶ’ мҡ°нҒҙлҰӯ ContextMenuм—җ мғүмғҒ/л‘җк»ҳ/мҠӨнҸ¬мқҙл“ң/Undo/Redo/Clear нҶөн•©.
           Ctrl+Z Undo, Ctrl+Shift+Z Redo. мӨҢ мӢң stroke мўҢн‘ң мҠӨмјҖмқј мң м§Җ. -->
<Window x:Class="Capture.Views.CapturedWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:Capture.Behaviors"
        behaviors:WindowDragBehavior.IsEnabled="True"
        Title="Capture It !"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Opacity="{Binding EffectiveOpacity}"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        KeyDown="OnKeyDown"
        PreviewKeyDown="OnPreviewKeyDown"
        PreviewKeyUp="OnPreviewKeyUp"
        Deactivated="OnDeactivated">

    <Window.InputBindings>
        <KeyBinding Key="Z" Modifiers="Control" Command="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=UndoCommand}"/>
        <KeyBinding Key="Z" Modifiers="Control+Shift" Command="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=RedoCommand}"/>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveAsCommand}"/>
    </Window.InputBindings>

    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Save As..." InputGestureText="Ctrl+S" Command="{Binding SaveAsCommand}"/>
            <Separator/>
            <MenuItem Header="Reset to Original Size" Command="{Binding ResetSizeCommand}"/>
            <Separator/>
            <MenuItem Header="Opacity">
                <MenuItem Header="100%" Command="{Binding SetOpacityCommand}" CommandParameter="1.0"/>
                <MenuItem Header="80%"  Command="{Binding SetOpacityCommand}" CommandParameter="0.8"/>
                <MenuItem Header="60%"  Command="{Binding SetOpacityCommand}" CommandParameter="0.6"/>
                <MenuItem Header="40%"  Command="{Binding SetOpacityCommand}" CommandParameter="0.4"/>
                <MenuItem Header="20%"  Command="{Binding SetOpacityCommand}" CommandParameter="0.2"/>
                <MenuItem Header="10%"  Command="{Binding SetOpacityCommand}" CommandParameter="0.1"/>
            </MenuItem>
            <Separator/>
            <MenuItem Header="Extract Channels">
                <MenuItem Header="RGB - R" Command="{Binding ExtractChannelCommand}" CommandParameter="RGB_R"/>
                <MenuItem Header="RGB - G" Command="{Binding ExtractChannelCommand}" CommandParameter="RGB_G"/>
                <MenuItem Header="RGB - B" Command="{Binding ExtractChannelCommand}" CommandParameter="RGB_B"/>
                <Separator/>
                <MenuItem Header="YUV - Y" Command="{Binding ExtractChannelCommand}" CommandParameter="YUV_Y"/>
                <MenuItem Header="YUV - U" Command="{Binding ExtractChannelCommand}" CommandParameter="YUV_U"/>
                <MenuItem Header="YUV - V" Command="{Binding ExtractChannelCommand}" CommandParameter="YUV_V"/>
                <Separator/>
                <MenuItem Header="HSV - H" Command="{Binding ExtractChannelCommand}" CommandParameter="HSV_H"/>
                <MenuItem Header="HSV - S" Command="{Binding ExtractChannelCommand}" CommandParameter="HSV_S"/>
                <MenuItem Header="HSV - V" Command="{Binding ExtractChannelCommand}" CommandParameter="HSV_V"/>
                <Separator/>
                <MenuItem Header="HLS - H" Command="{Binding ExtractChannelCommand}" CommandParameter="HLS_H"/>
                <MenuItem Header="HLS - L" Command="{Binding ExtractChannelCommand}" CommandParameter="HLS_L"/>
                <MenuItem Header="HLS - S" Command="{Binding ExtractChannelCommand}" CommandParameter="HLS_S"/>
            </MenuItem>
            <!-- natural-fix: "Calcaulate Histogram" вҶ’ "Calculate Histogram" -->
            <MenuItem Header="Calculate Histogram" Command="{Binding ShowHistogramCommand}"/>
            <Separator/>
            <!-- л“ңлЎңмһү лҸ„кө¬ вҖ” лЈЁнҠё м»Ён…ҚмҠӨнҠё л©”лүҙм—җ м§Ғм ‘ л°°м№ҳ(нҸүнғ„нҷ”). -->
            <MenuItem Header="Pen Color">
                <MenuItem x:Name="MenuColor0" Header="Black"   Tag="#FF000000" IsCheckable="True" Click="ColorMenu_Click"/>
                <MenuItem x:Name="MenuColor1" Header="White"   Tag="#FFFFFFFF" IsCheckable="True" Click="ColorMenu_Click"/>
                <MenuItem x:Name="MenuColor2" Header="Red"     Tag="#FFFF3B30" IsCheckable="True" Click="ColorMenu_Click"/>
                <MenuItem x:Name="MenuColor3" Header="Magenta" Tag="#FFE91E63" IsCheckable="True" IsChecked="True" Click="ColorMenu_Click"/>
                <MenuItem x:Name="MenuColor4" Header="Yellow"  Tag="#FFFFC107" IsCheckable="True" Click="ColorMenu_Click"/>
                <MenuItem x:Name="MenuColor5" Header="Green"   Tag="#FF34C759" IsCheckable="True" Click="ColorMenu_Click"/>
                <MenuItem x:Name="MenuColor6" Header="Blue"    Tag="#FF007AFF" IsCheckable="True" Click="ColorMenu_Click"/>
                <MenuItem x:Name="MenuColor7" Header="Cyan"    Tag="#FF5AC8FA" IsCheckable="True" Click="ColorMenu_Click"/>
            </MenuItem>
            <MenuItem Header="Pen Thickness">
                <MenuItem x:Name="MenuThick0" Header="Thin (2 px)"   Tag="2" IsCheckable="True" Click="ThickMenu_Click"/>
                <MenuItem x:Name="MenuThick1" Header="Medium (4 px)" Tag="4" IsCheckable="True" IsChecked="True" Click="ThickMenu_Click"/>
                <MenuItem x:Name="MenuThick2" Header="Thick (8 px)"  Tag="8" IsCheckable="True" Click="ThickMenu_Click"/>
            </MenuItem>
            <MenuItem x:Name="MenuEyedropper" Header="Eyedropper (pick color)" IsCheckable="True" Click="EyedropperMenu_Click"/>
            <MenuItem Header="Clear All Drawings" Click="ClearStrokesMenuItem_Click"/>
            <Separator/>
            <MenuItem Header="Close" Click="CloseMenuItem_Click"/>
        </ContextMenu>
    </Window.ContextMenu>

    <!-- мҷёкіҪ chrome м ңкұ°: м»ҙнҢ©нҠё лӘЁл“ңмқҳ мӮ¬к°Ғ 1px DimGray н…Ңл‘җлҰ¬к°Җ лқјмҡҙл“ң м№ҙл“ң л°–м—җ мӮ¬к°Ғнҳ•мңјлЎң л…ём¶ңлҗҳлҚҳ л¬ём ң н•ҙкІ°.
         мқјл°ҳ лӘЁл“ңмқҳ 1px н…Ңл‘җлҰ¬лҠ” Image лҘј к°җмӢёлҠ” лӮҙл¶Җ Border лЎң мҳ®кІЁ к·ёлҢҖлЎң мң м§Җ. -->
    <Grid>
        <!-- мқјл°ҳ лӘЁл“ң: мқҙлҜём§Җ + InkCanvas мҳӨлІ„л Ҳмқҙ + мҡ°мғҒлӢЁ нҢ”л ҲнҠё -->
        <Border BorderBrush="DimGray" BorderThickness="3"
                Visibility="{Binding IsNormal, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <!-- MouseMove/MouseLeave м¶”к°Җ вҖ” мҠӨнҸ¬мқҙл“ң лӘЁл“ң лҜёлҰ¬ліҙкё°. MouseDownмқҖ лҚ”лё”нҒҙлҰӯ м»ҙнҢ©нҠё нҶ кёҖ + мҠӨнҸ¬мқҙл“ң н”Ҫ -->
                <Image x:Name="MainImage"
                       Source="{Binding DisplayedImage}"
                       Stretch="None"
                       MouseDown="Image_MouseDown"
                       MouseMove="Image_MouseMove"
                       MouseLeave="Image_MouseLeave"
                       behaviors:MouseWheelZoomBehavior.Command="{Binding MouseWheelCommand}"
                       behaviors:DropImageBehavior.Command="{Binding DropFileCommand}"/>

                <!-- л“ңлЎңмһү InkCanvas вҖ” ImageмҷҖ к°ҷмқҖ мўҢн‘ң/нҒ¬кё°.
                     нҸүмҶҢ EditingMode=None + IsHitTestVisible=FalseлЎң лӘЁл“  мһ…л Ҙ нҶөкіј.
                     Ctrl лҲ„лҰ„ вҶ’ мҪ”л“ңл№„н•ҳмқёл“ңм—җм„ң EditingMode=Ink + hit-test on. -->
                <InkCanvas x:Name="DrawingCanvas"
                           Width="{Binding ElementName=MainImage, Path=ActualWidth}"
                           Height="{Binding ElementName=MainImage, Path=ActualHeight}"
                           HorizontalAlignment="Left" VerticalAlignment="Top"
                           Background="Transparent"
                           EditingMode="None"
                           IsHitTestVisible="False"/>

                <!-- мҠӨнҸ¬мқҙл“ң лҜёлҰ¬ліҙкё° Popup вҖ” 11Г—11 н”Ҫм…Җмқ„ ~140Г—140 мңјлЎң нҷ•лҢҖ + к°ҖмҡҙлҚ° мӢӯмһҗ + мғү лқјлІЁ -->
                <Popup x:Name="EyedropperPopup"
                       Placement="Relative"
                       PlacementTarget="{Binding ElementName=MainImage}"
                       AllowsTransparency="True"
                       IsHitTestVisible="False"
                       StaysOpen="True"
                       IsOpen="False">
                    <Border Background="#E61A1A1C"
                            CornerRadius="10"
                            Padding="6"
                            BorderBrush="#80FFFFFF"
                            BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.6" Color="Black"/>
                        </Border.Effect>
                        <StackPanel>
                            <Grid Width="140" Height="140">
                                <Image x:Name="EyedropperPreviewImage"
                                       Width="140" Height="140"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                                       SnapsToDevicePixels="True"
                                       Stretch="Fill"/>
                                <!-- к°ҖмҡҙлҚ° 1Г—1 н”Ҫм…Җ(12.7 DIP) мӮ¬к°Ғ к°•мЎ° + 4л°©н–Ҙ к°Җмқҙл“ң лқјмқё -->
                                <Rectangle Width="12.7" Height="12.7"
                                           Stroke="#FFE91E63" StrokeThickness="1"
                                           Fill="Transparent"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <Line X1="0" Y1="70" X2="63.65" Y2="70" Stroke="#FFE91E63" StrokeThickness="1"/>
                                <Line X1="76.35" Y1="70" X2="140" Y2="70" Stroke="#FFE91E63" StrokeThickness="1"/>
                                <Line X1="70" Y1="0" X2="70" Y2="63.65" Stroke="#FFE91E63" StrokeThickness="1"/>
                                <Line X1="70" Y1="76.35" X2="70" Y2="140" Stroke="#FFE91E63" StrokeThickness="1"/>
                                <!-- мҷёкіҪ 1px ліҙлҚ” -->
                                <Rectangle Width="140" Height="140"
                                           Stroke="#80FFFFFF" StrokeThickness="0.6" Fill="Transparent"/>
                            </Grid>
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="EyedropperSwatch" Grid.Column="0"
                                        Width="20" Height="20" CornerRadius="4"
                                        Background="#000000"
                                        BorderBrush="#80FFFFFF" BorderThickness="1"
                                        VerticalAlignment="Center"
                                        Margin="0,0,8,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock x:Name="EyedropperHexText" Text="#000000"
                                               FontFamily="Consolas" FontSize="13" FontWeight="SemiBold"
                                               Foreground="White"/>
                                    <TextBlock x:Name="EyedropperRgbText" Text="RGB(0, 0, 0)"
                                               FontFamily="Consolas" FontSize="11"
                                               Foreground="#B0FFFFFF"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>
        </Border>

            <!-- м»ҙнҢ©нҠё мқёл””мјҖмқҙн„° вҖ” лӘЁлҚҳ м№ҙл“ң (Bм•Ҳ)
                 60Г—60, CornerRadius=14, мҚёл„Өмқј мң„м—җ н•ҳлӢЁ м–ҙл‘җмҡҙ к·ёлқјл””м–ёнҠё мҳӨлІ„л Ҳмқҙ,
                 к°ҖмҡҙлҚ° нҺјм№Ё(вҶ—) м•„мқҙмҪҳ. нҳёлІ„ мӢң к·ёлқјл””м–ёнҠё м•Ҫнҷ” + мӮҙм§қ нҷ•лҢҖлЎң мҚёл„Өмқјмқҙ лҳҗл ·н•ҙм§җ.
                 ShadowDepth=0 + BlurRadius=14 лЎң лҢҖм№ӯ н—ӨмқјлЎң(нҺёмӨ‘ X), Margin=28 лЎң к·ёлҰјмһҗ нҺҳмқҙл“ңм•„мӣғмқҙ
                 Window кІҪкі„ м•Ҳм—җм„ң лҒқлӮҳлҸ„лЎқ н•Ё вҖ” мӮ¬к°Ғ мңӨкіҪ нҒҙлҰҪ мҷ„м „ м ңкұ°. -->
            <Border Width="60" Height="60"
                    Margin="28"
                    CornerRadius="14"
                    Background="#1A1A1C"
                    Cursor="Hand"
                    RenderTransformOrigin="0.5,0.5"
                    Visibility="{Binding IsCompact, Converter={StaticResource BoolToVisibilityConverter}}"
                    MouseLeftButtonDown="CompactIndicator_MouseLeftButtonDown">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="0" Opacity="0.55" Color="Black"/>
                </Border.Effect>
                <Border.RenderTransform>
                    <ScaleTransform x:Name="CompactScale" ScaleX="1" ScaleY="1"/>
                </Border.RenderTransform>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="CompactScale"
                                                 Storyboard.TargetProperty="ScaleX"
                                                 To="1.06" Duration="0:0:0.12"/>
                                <DoubleAnimation Storyboard.TargetName="CompactScale"
                                                 Storyboard.TargetProperty="ScaleY"
                                                 To="1.06" Duration="0:0:0.12"/>
                                <DoubleAnimation Storyboard.TargetName="OverlayGradient"
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="0.25" Duration="0:0:0.15"/>
                                <DoubleAnimation Storyboard.TargetName="ExpandIcon"
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="1.0" Duration="0:0:0.15"/>
                                <DoubleAnimation Storyboard.TargetName="ExpandScale"
                                                 Storyboard.TargetProperty="ScaleX"
                                                 To="1.18" Duration="0:0:0.18"/>
                                <DoubleAnimation Storyboard.TargetName="ExpandScale"
                                                 Storyboard.TargetProperty="ScaleY"
                                                 To="1.18" Duration="0:0:0.18"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="CompactScale"
                                                 Storyboard.TargetProperty="ScaleX"
                                                 To="1.0" Duration="0:0:0.12"/>
                                <DoubleAnimation Storyboard.TargetName="CompactScale"
                                                 Storyboard.TargetProperty="ScaleY"
                                                 To="1.0" Duration="0:0:0.12"/>
                                <DoubleAnimation Storyboard.TargetName="OverlayGradient"
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="0.7" Duration="0:0:0.15"/>
                                <DoubleAnimation Storyboard.TargetName="ExpandIcon"
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="0.85" Duration="0:0:0.15"/>
                                <DoubleAnimation Storyboard.TargetName="ExpandScale"
                                                 Storyboard.TargetProperty="ScaleX"
                                                 To="1.0" Duration="0:0:0.18"/>
                                <DoubleAnimation Storyboard.TargetName="ExpandScale"
                                                 Storyboard.TargetProperty="ScaleY"
                                                 To="1.0" Duration="0:0:0.18"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
                <Grid>
                    <!-- 1) мәЎмІҳ мҚёл„Өмқј вҖ” Image мһҗмӢқмқҙ м•„лӢҲлқј ImageBrush лЎң м№ н•ҙм•ј CornerRadius к°Җ
                         мӢӨм ңлЎң н”Ҫм…Җм—җ м Ғмҡ©лҗңлӢӨ(WPF Border ClipToBounds лҠ” лқјмҡҙл“ң нҒҙлҰҪмқҙ м•„лӢҲлқј мӮ¬к°Ғ нҒҙлҰҪ). -->
                    <Border CornerRadius="13">
                        <Border.Background>
                            <ImageBrush ImageSource="{Binding DisplayedImage}" Stretch="UniformToFill"/>
                        </Border.Background>
                    </Border>
                    <!-- 2) н•ҳлӢЁ к·ёлқјл””м–ёнҠё мҳӨлІ„л Ҳмқҙ (к°ҖлҸ…м„ұ + нҺјм№Ё м•„мқҙмҪҳ л°°кІҪ) -->
                    <Border x:Name="OverlayGradient" CornerRadius="13" Opacity="0.7">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#00000000" Offset="0.0"/>
                                <GradientStop Color="#00000000" Offset="0.45"/>
                                <GradientStop Color="#B0000000" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <!-- 3) нҺјм№Ё мқёл””мјҖмқҙн„° вҖ” "лӮҙ л°©н–Ҙ нҢҪм°Ҫ" м»Ём…ү (мЎ°лҰ¬к°ң л“ҖмҳӨнҶӨкіј мқјкҙҖ)
                         мӨ‘м•ҷ мӮ¬к°Ғ(нҷ”мқҙнҠё лқјмқё) + 4мҪ”л„Ҳ г„ұмһҗ к°Җмқҙл“ң(л§Ҳм  нғҖ #E91E63) вҖ” м№ҙл©”лқј л·°нҢҢмқёлҚ” мҪ”л„Ҳ л§Ҳм»Ө
                         нҳёлІ„ мӢң ScaleTransform 1.0вҶ’1.18 + Opacity 0.85вҶ’1.0 мңјлЎң мӮ¬мҡ©мһҗ мӘҪмңјлЎң нҢҪм°Ҫ. -->
                    <Grid x:Name="ExpandIcon"
                          Width="14" Height="14"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Opacity="0.85"
                          RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="ExpandScale" ScaleX="1" ScaleY="1"/>
                        </Grid.RenderTransform>
                        <Grid.Effect>
                            <DropShadowEffect BlurRadius="3" ShadowDepth="0" Opacity="0.9" Color="Black"/>
                        </Grid.Effect>
                        <Path Data="M 4,4 L 10,4 L 10,10 L 4,10 Z"
                              Stroke="#F0FFFFFF" StrokeThickness="1.3"
                              StrokeLineJoin="Round"/>
                        <Path Data="M 3,1 L 1,1 L 1,3 M 11,1 L 13,1 L 13,3 M 1,11 L 1,13 L 3,13 M 13,11 L 13,13 L 11,13"
                              Stroke="#FFE91E63" StrokeThickness="1.6"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"/>
                    </Grid>
                    <!-- 4) мҷёкіҪ ліҙлҚ” вҖ” лӢӨнҒ¬/лқјмқҙнҠё 2лӢЁмңјлЎң мһ…мІҙк°җ -->
                    <Border CornerRadius="14" BorderBrush="DimGray" BorderThickness="2"/>
                    <Border CornerRadius="13" BorderBrush="#40FFFFFF" BorderThickness="0.6" Margin="2"/>
                </Grid>
            </Border>
    </Grid>
</Window>
