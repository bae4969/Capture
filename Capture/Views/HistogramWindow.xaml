<!-- author: eng-fe-desktop -->
<!-- phase: engineering -->
<!-- 8차: ImageJ 스타일 전체 재작성 (480×440 권장, 헤더 + Canvas 그래프 + gradient bar + 통계 + 버튼) -->
<!-- 9차: Live 버튼 제거. 4개 버튼(List/Copy/Log/RGB) IsEnabled=True + Command 바인딩 + DataTrigger 토글 색 -->
<Window x:Class="Capture.Views.HistogramWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Histogram"
        Width="480" Height="440"
        MinWidth="320" MinHeight="300"
        ResizeMode="CanResize"
        WindowStartupLocation="Manual"
        Topmost="True"
        Background="#F0F0F0"
        KeyDown="OnKeyDown">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <!-- 헤더 텍스트 -->
            <RowDefinition Height="Auto"/>
            <!-- 그래프 Canvas -->
            <RowDefinition Height="*"/>
            <!-- gradient bar + 라벨 -->
            <RowDefinition Height="Auto"/>
            <!-- 통계 그리드 -->
            <RowDefinition Height="Auto"/>
            <!-- 버튼 행 -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── 헤더 텍스트 ──────────────────────────────────────────────────── -->
        <TextBlock Grid.Row="0"
                   Text="{Binding HeaderText}"
                   FontSize="11"
                   FontFamily="Consolas"
                   Margin="0,0,0,4"
                   VerticalAlignment="Center"/>

        <!-- ── 히스토그램 Canvas — 코드비하인드 DrawHistogram ───────────────── -->
        <Border Grid.Row="1"
                BorderBrush="#5E81C4" BorderThickness="1"
                Background="White"
                Margin="0,0,0,4">
            <Canvas x:Name="HistogramCanvas"
                    Background="White"
                    SizeChanged="HistogramCanvas_SizeChanged"
                    MouseMove="HistogramCanvas_MouseMove"
                    MouseLeave="HistogramCanvas_MouseLeave"/>
        </Border>

        <!-- ── Gradient bar + 라벨 ──────────────────────────────────────────── -->
        <Grid Grid.Row="2" Margin="0,0,0,6">
            <Grid.RowDefinitions>
                <RowDefinition Height="14"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 0→255 Grayscale gradient -->
            <Rectangle Grid.Row="0" Height="14">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="Black" Offset="0"/>
                        <GradientStop Color="White" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- 라벨 행 -->
            <Grid Grid.Row="1" Margin="0,2,0,0">
                <TextBlock Text="0"
                           FontSize="10"
                           HorizontalAlignment="Left"/>
                <TextBlock Text="Intensity (unweighted)"
                           FontSize="10"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="255"
                           FontSize="10"
                           HorizontalAlignment="Right"/>
            </Grid>
        </Grid>

        <!-- ── 통계 그리드 (2열 4행) ─────────────────────────────────────────── -->
        <Border Grid.Row="3"
                BorderBrush="#CCCCCC" BorderThickness="1"
                Background="White"
                Margin="0,0,0,8"
                Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 0 -->
                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="N: " FontWeight="SemiBold" FontSize="11"/>
                    <TextBlock Text="{Binding TotalPixels}" FontSize="11"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="Min: " FontWeight="SemiBold" FontSize="11"/>
                    <TextBlock Text="{Binding Min}" FontSize="11"/>
                </StackPanel>

                <!-- Row 1 -->
                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Mean: " FontWeight="SemiBold" FontSize="11"/>
                    <TextBlock Text="{Binding Mean, StringFormat={}{0:0.000}}" FontSize="11"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="Max: " FontWeight="SemiBold" FontSize="11"/>
                    <TextBlock Text="{Binding Max}" FontSize="11"/>
                </StackPanel>

                <!-- Row 2 -->
                <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="StdDev: " FontWeight="SemiBold" FontSize="11"/>
                    <TextBlock Text="{Binding StdDev, StringFormat={}{0:0.000}}" FontSize="11"/>
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="Mode: " FontWeight="SemiBold" FontSize="11"/>
                    <TextBlock FontSize="11">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0} ({1})">
                                <Binding Path="Mode"/>
                                <Binding Path="ModeCount"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>

                <!-- Row 3 — hover -->
                <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Value: " FontWeight="SemiBold" FontSize="11"/>
                    <TextBlock Text="{Binding HoverValue}" FontSize="11"/>
                </StackPanel>
                <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="Count: " FontWeight="SemiBold" FontSize="11"/>
                    <TextBlock Text="{Binding HoverCount}" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── 버튼 행 (9차: Live 제거, 4개 구현 — List/Copy/Log/RGB) ─────── -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center">
            <StackPanel.Resources>
                <Style TargetType="Button">
                    <Setter Property="Width" Value="64"/>
                    <Setter Property="Height" Value="24"/>
                    <Setter Property="Margin" Value="3,0"/>
                    <Setter Property="IsEnabled" Value="True"/>
                    <Setter Property="FontSize" Value="11"/>
                </Style>
            </StackPanel.Resources>
            <!-- List: 256 bin 텍스트 창 표시 -->
            <Button Content="List" Command="{Binding ShowListCommand}"/>
            <!-- Copy: 통계 텍스트 클립보드 복사 -->
            <Button Content="Copy" Command="{Binding CopyStatisticsCommand}"/>
            <!-- Log: 로그 스케일 토글 — 활성 시 파란 배경 -->
            <Button Content="Log" Command="{Binding ToggleLogCommand}"
                    x:Name="LogButton">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Width" Value="64"/>
                        <Setter Property="Height" Value="24"/>
                        <Setter Property="Margin" Value="3,0"/>
                        <Setter Property="IsEnabled" Value="True"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLogScale}" Value="True">
                                <Setter Property="Background" Value="#5E81C4"/>
                                <Setter Property="Foreground" Value="White"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <!-- 11차: 채널 순환 (Gray → R → G → B → Gray) — 버튼 Content 가 현재 채널 표시 -->
            <Button Content="{Binding ChannelLabel}" Command="{Binding CycleChannelCommand}"
                    x:Name="ChannelButton" ToolTip="Click to cycle: Gray → R → G → B">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Width" Value="64"/>
                        <Setter Property="Height" Value="24"/>
                        <Setter Property="Margin" Value="3,0"/>
                        <Setter Property="IsEnabled" Value="True"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ChannelLabel}" Value="R">
                                <Setter Property="Background" Value="#DC3232"/>
                                <Setter Property="Foreground" Value="White"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ChannelLabel}" Value="G">
                                <Setter Property="Background" Value="#32B432"/>
                                <Setter Property="Foreground" Value="White"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ChannelLabel}" Value="B">
                                <Setter Property="Background" Value="#3264DC"/>
                                <Setter Property="Foreground" Value="White"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>
